# ==============================================
# GHAAFEEDI MUSIC - ENVIRONMENT CONFIGURATION
# ==============================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to Git (already in .gitignore)

# ==============================================
# SUPABASE DATABASE
# ==============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==============================================
# FIREBASE AUTHENTICATION
# ==============================================
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ==============================================
# PAYMENT PROCESSORS
# ==============================================

# Dodo Payment
DODO_API_KEY=your-dodo-api-key-here
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret-here

# Lemon Squeezy
LEMON_SQUEEZY_API_KEY=your-lemon-squeezy-api-key-here
LEMON_SQUEEZY_WEBHOOK_SECRET=your-lemon-squeezy-webhook-secret-here

# Stripe
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Coinbase Commerce
COINBASE_API_KEY=your-coinbase-api-key-here
COINBASE_WEBHOOK_SECRET=your-coinbase-webhook-secret-here

# ==============================================
# APPLICATION SETTINGS
# ==============================================
NEXT_PUBLIC_APP_URL=https://www.ghaafeedimusic.com
NODE_ENV=production

# Build Settings (for Vercel deployment)
NODE_OPTIONS=--max-old-space-size=8192

# ==============================================
# AI/ML SERVICES (Optional - for future features)
# ==============================================
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# REPLICATE_API_KEY=your-replicate-api-key-here

# ==============================================
# EMAIL SERVICE (Optional - for notifications)
# ==============================================
# RESEND_API_KEY=your-resend-api-key-here
# SENDGRID_API_KEY=your-sendgrid-api-key-here

# ==============================================
# MONITORING & ANALYTICS (Optional)
# ==============================================
# SENTRY_DSN=your-sentry-dsn-here
# VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# ==============================================
# SECURITY NOTES
# ==============================================
# 1. Never commit this file with real values to Git
# 2. Use Vercel Dashboard to set production environment variables
# 3. Rotate all API keys and secrets regularly
# 4. Use different keys for development/staging/production
# 5. Enable webhook signature verification for all payment providers
# 6. Use HTTPS only in production (enforced by vercel.json)